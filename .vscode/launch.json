{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ImageConverter: convert interactive range",
      "type": "debugpy",
      "request": "launch",
      "module": "src.imageCompositeConverter",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "artifacts/images_to_convert",
        "--descriptions-path",
        "artifacts/descriptions/Finale_Wurzelformen_V3.xml",
        "--interactive-range"
      ],
      "justMyCode": false
    },
    {
      "name": "ImageConverter: annotate interactive range",
      "type": "debugpy",
      "request": "launch",
      "module": "src.imageCompositeConverter",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "artifacts/images_to_convert",
        "--mode",
        "annotate",
        "--interactive-range"
      ],
      "justMyCode": false
    },
    {
      "name": "ImageConverter: convert all SVGs",
      "type": "debugpy",
      "request": "launch",
      "module": "src.imageCompositeConverter",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "artifacts/images_to_convert",
        "--descriptions-path",
        "artifacts/descriptions/Finale_Wurzelformen_V3.xml",
        "--output-dir",
        "artifacts/converted_images",
        "--start",
        "AC0000",
        "--end",
        "ZZ9999"
      ],
      "justMyCode": false
    }
  ]
}
