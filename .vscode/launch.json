{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: image_composite_converter (interactive range)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/image_composite_converter.py",
      "python": "${config:python.defaultInterpreterPath}",
      "args": [
        "--interactive-range",
        "${workspaceFolder}/artifacts/images_to_convert"
      ],
      "console": "integratedTerminal",
      "logToFile": true,
      "justMyCode": false
    }
  ]
}
