{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ImageConverter: convert interactive range",
      "type": "debugpy",
      "request": "launch",
      "module": "src.image_composite_converter",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "artifacts/images_to_convert",
        "--interactive-range"
      ],
      "justMyCode": false
    },
    {
      "name": "ImageConverter: update successful conversion manifest quality",
      "type": "debugpy",
      "request": "launch",
      "module": "src.successful_conversion_quality_app",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [],
      "justMyCode": false
    },
    {
      "name": "ImageConverter: annotate interactive range",
      "type": "debugpy",
      "request": "launch",
      "module": "src.image_composite_converter",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "artifacts/images_to_convert",
        "--mode",
        "annotate",
        "--interactive-range"
      ],
      "justMyCode": false
    }
  ]
}
